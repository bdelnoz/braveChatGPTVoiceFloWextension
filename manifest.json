{
  "manifest_version": 3,
  "name": "ChatGPT Voice Flow",
  "version": "11.3.0",
  "description": "ChatGPT Voice Flow dev build. v11.3.0 changes header close into a mini VF button instead of hiding the widget.",
  "action": {
    "default_title": "ChatGPT Voice Flow v11.3.0",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "audioCapture",
    "nativeMessaging"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "content-autosend.js"
      ],
      "css": [
        "autosend-style.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "short_name": "Voice Flow",
  "version_name": "v11.3.0 Mini Button Fix - compact restore widget"
}
